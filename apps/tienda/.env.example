# URL base del ERP (apps/erp). En dev local el ERP corre en el puerto 3000.
WEBSTORE_API_URL='http://localhost:3000'

# API key generada en el ERP: /webstore/api-keys (se muestra una sola vez),
# o con `pnpm dlx tsx scripts/create-webstore-key.ts` desde apps/erp.
# Necesita scopes read_catalog, create_orders y manage_customers.
WEBSTORE_API_KEY=''

# Umbral de envío gratis y costo de envío a domicilio, en la moneda BASE del
# ERP (hoy CUP, 0 decimales). Defaults: 63500 CUP (~$100 USD) y 3200 CUP
# (~$5 USD) a 635 CUP/USD. La tienda nunca convierte monedas — estos son
# montos de negocio en la moneda que declare el catálogo (currency.code).
NEXT_PUBLIC_FREE_SHIPPING_TARGET=63500
NEXT_PUBLIC_SHIPPING_COST=3200
