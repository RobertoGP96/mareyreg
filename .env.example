# Database connection (server-only, NO VITE_ prefix)
DATABASE_URL='postgresql://user:password@host/database?sslmode=require'

# Auth.js
NEXTAUTH_SECRET='generate-with-openssl-rand-base64-32'
NEXTAUTH_URL='http://localhost:3000'

# Neon API (server-only, for storage monitoring)
NEON_API_KEY='your-neon-api-key'

# Vercel Blob (server-only, para uploads de contratos)
# Crea un store en https://vercel.com/<team>/<project>/stores y copia el token.
BLOB_READ_WRITE_TOKEN='vercel_blob_rw_...'
