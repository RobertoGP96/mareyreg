{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "erp",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "--filter", "erp", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "tienda",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "--filter", "tienda", "dev"],
      "port": 3001
    },
    {
      "name": "tienda-prod",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "--filter", "tienda", "start"],
      "port": 3001
    },
    {
      "name": "tienda-preview",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "--filter", "tienda", "exec", "next", "dev", "--turbopack"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
